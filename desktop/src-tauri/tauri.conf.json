{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixiv PBD Manager",
  "version": "0.1.0",
  "identifier": "com.jfpv.pixivpbdmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pixiv PBD Manager",
        "width": 1180,
        "height": 800,
        "minWidth": 980,
        "minHeight": 660
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
