{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for Pixiv PBD Manager.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python",
          "cmd": "python",
          "args": [
            "-m",
            "pixiv_pbd_manager.gui_api",
            {
              "validator": "^(?:settings\\.get|settings\\.save|artists\\.list|artists\\.add|artists\\.rename|artists\\.set_save_path|scan\\.run|updates\\.check|updates\\.download|similar\\.run|browser\\.open|file\\.reveal|cookie\\.revoke)$"
            },
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "py",
          "cmd": "py",
          "args": [
            "-m",
            "pixiv_pbd_manager.gui_api",
            {
              "validator": "^(?:settings\\.get|settings\\.save|artists\\.list|artists\\.add|artists\\.rename|artists\\.set_save_path|scan\\.run|updates\\.check|updates\\.download|similar\\.run|browser\\.open|file\\.reveal|cookie\\.revoke)$"
            },
            {
              "validator": ".+"
            }
          ]
        }
      ]
    }
  ]
}
