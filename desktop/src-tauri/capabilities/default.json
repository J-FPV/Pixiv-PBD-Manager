{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for Pixiv PBD Manager.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-maximize",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python",
          "cmd": "python",
          "args": [
            "-m",
            "pixiv_pbd_manager.gui_api",
            {
              "validator": "^(?:settings\\.get|settings\\.save|artists\\.list|artists\\.add|artists\\.assign_folder|artists\\.remove|artists\\.refresh_names|artists\\.rebuild_work_index\\.preview|artists\\.rebuild_work_index\\.apply|artists\\.rename|artists\\.set_save_path|artists\\.set_favorite|artists\\.set_tags|artists\\.add_tag|artists\\.assign_tag|artists\\.rename_tag|artists\\.delete_tag|scan\\.run|scan\\.preview|scan\\.apply|updates\\.check|updates\\.download|similar\\.run|library\\.list|library\\.status|library\\.scan|library\\.set_tags|library\\.update_metadata|library\\.export|library\\.fetch_tags|cleanup\\.list|cleanup\\.quarantine|cleanup\\.restore|cleanup\\.delete|cleanup\\.ignore|cleanup\\.unignore|doctor\\.run|app\\.latest_release|browser\\.open|file\\.reveal|image\\.thumbnail|image\\.difference|cookie\\.revoke)$"
            },
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "py",
          "cmd": "py",
          "args": [
            "-m",
            "pixiv_pbd_manager.gui_api",
            {
              "validator": "^(?:settings\\.get|settings\\.save|artists\\.list|artists\\.add|artists\\.assign_folder|artists\\.remove|artists\\.refresh_names|artists\\.rebuild_work_index\\.preview|artists\\.rebuild_work_index\\.apply|artists\\.rename|artists\\.set_save_path|artists\\.set_favorite|artists\\.set_tags|artists\\.add_tag|artists\\.assign_tag|artists\\.rename_tag|artists\\.delete_tag|scan\\.run|scan\\.preview|scan\\.apply|updates\\.check|updates\\.download|similar\\.run|library\\.list|library\\.status|library\\.scan|library\\.set_tags|library\\.update_metadata|library\\.export|library\\.fetch_tags|cleanup\\.list|cleanup\\.quarantine|cleanup\\.restore|cleanup\\.delete|cleanup\\.ignore|cleanup\\.unignore|doctor\\.run|app\\.latest_release|browser\\.open|file\\.reveal|image\\.thumbnail|image\\.difference|cookie\\.revoke)$"
            },
            {
              "validator": ".+"
            }
          ]
        },
        {
          "name": "pixiv-pbd-api",
          "cmd": "pixiv-pbd-api/pixiv-pbd-api.exe",
          "args": [
            {
              "validator": "^(?:settings\\.get|settings\\.save|artists\\.list|artists\\.add|artists\\.assign_folder|artists\\.remove|artists\\.refresh_names|artists\\.rebuild_work_index\\.preview|artists\\.rebuild_work_index\\.apply|artists\\.rename|artists\\.set_save_path|artists\\.set_favorite|artists\\.set_tags|artists\\.add_tag|artists\\.assign_tag|artists\\.rename_tag|artists\\.delete_tag|scan\\.run|scan\\.preview|scan\\.apply|updates\\.check|updates\\.download|similar\\.run|library\\.list|library\\.status|library\\.scan|library\\.set_tags|library\\.update_metadata|library\\.export|library\\.fetch_tags|cleanup\\.list|cleanup\\.quarantine|cleanup\\.restore|cleanup\\.delete|cleanup\\.ignore|cleanup\\.unignore|doctor\\.run|app\\.latest_release|browser\\.open|file\\.reveal|image\\.thumbnail|image\\.difference|cookie\\.revoke)$"
            },
            {
              "validator": ".+"
            }
          ]
        }
      ]
    }
  ]
}
