{
  "name": "pixiv-pbd-manager-desktop",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "dev:mock": "vite --mode mock --host 127.0.0.1 --port 1421 --strictPort",
    "lint": "eslint .",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "test:e2e": "playwright test",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --config src-tauri/tauri.release.conf.json"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.1.4"
  }
}
